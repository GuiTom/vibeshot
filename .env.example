# Environment Variables

# OpenAI API Key (for image generation with GPT Image models)
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL
DATABASE_URL="postgresql://spike:@localhost:5432/aimusic"

# Auth.js
AUTH_SECRET=replace_with_a_long_random_secret
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret
AUTH_FACEBOOK_ID=your_facebook_app_id
AUTH_FACEBOOK_SECRET=your_facebook_app_secret

# Optional: Custom API endpoint (for proxy services like OpenRouter)
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optional: Azure OpenAI Service (alternative)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your_azure_api_key
